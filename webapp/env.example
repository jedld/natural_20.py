# LLM Configuration Example
# Copy this file to .env and modify the values as needed

# LLM Provider Selection (choose one)
# Options: llama_cpp, openai, anthropic, ollama, mock
LLM_PROVIDER=llama_cpp

# OpenAI Configuration
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Configuration
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# llama.cpp Configuration (default)
LLAMA_CPP_BASE_URL=http://localhost:8011
# LLAMA_CPP_MODEL=your-loaded-model-name
LLAMA_CPP_API_KEY=llama-cpp

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:27b

# NPC LLM Configuration (separate from DM AI assistant)
# Use a faster/cheaper model for NPC conversations while keeping the DM AI
# on a larger model. Set NPC_LLM_ENABLED=0 to disable and fall back to the
# DM provider for NPC chat.
#
# NPC_LLM_ENABLED=1                              # enable NPC provider (default)
# NPC_LLM_PROVIDER=ollama                        # ollama|openai|anthropic|llama_cpp|mock
# NPC_BASE_URL=http://jedld-strix.local:52627    # optional: override base URL entirely
# NPC_OLLAMA_BASE_URL=http://localhost:11434     # optional: per-provider URL fallback
# NPC_MODEL=gemma4:latest                        # optional: override NPC model name
# NPC_OPENAI_API_KEY=sk-...                      # optional: override API key per-provider
#
# Timeout Configuration (in seconds)
# Increase these values for ECS/AWS environments where network latency may be higher
OPENAI_TIMEOUT=60
ANTHROPIC_TIMEOUT=60
OLLAMA_TIMEOUT=60
LLAMA_CPP_TIMEOUT=60

# Application Configuration
FLASK_ENV=development
TEMPLATE_DIR=../templates

# CORS Configuration
# Comma-separated list of allowed origins (e.g., "http://localhost:5000,https://myapp.com")
# If not set, defaults will be used based on environment
# CORS_ORIGINS=http://localhost:5000,http://localhost:5001,https://myapp.com 