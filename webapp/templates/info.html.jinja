<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>D&D Character Sheet</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="/styles.css?salt={{ salt }}" rel="stylesheet">
    <link href="/sheet.css?salt={{ salt }}" rel="stylesheet">
    
    <link href="https://fonts.googleapis.com/css?family=Cinzel|Uncial+Antiqua|IM+Fell+English" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <style>
        body {
            font-family: 'Times New Roman', serif;
            background: beige;
            padding: 20px;
        }
        .sheet {
            background: white;
            max-width: 800px;
            margin: auto;
            padding: 20px;
            border: 1px solid #ccc;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        h1, h2, h3 {
            color: darkred;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            border: 1px solid black;
            padding: 8px;
            text-align: left;
        }
        th {
            background-color: #f2f2f2;
        }
        /* Tab Styling */
        .tab {
            overflow: hidden;
            border: 1px solid #ccc;
            background-color: #f1f1f1;
        }
        .tab button {
            background-color: inherit;
            float: left;
            border: none;
            outline: none;
            cursor: pointer;
            padding: 14px 16px;
            transition: 0.3s;
            font-size: 17px;
        }
        .tab button:hover {
            background-color: #ddd;
        }
        .tab button.active {
            background-color: #ccc;
        }
        .tabcontent {
            display: none;
            padding: 6px 12px;
            border: 1px solid #ccc;
            border-top: none;
        }

        /* Features & Traits Styling */
        .features-container {
            margin: 20px 0;
            padding: 15px;
            background: #f9f9f9;
            border-radius: 5px;
        }
        .feature-section {
            margin-bottom: 20px;
        }
        .feature-section h3 {
            color: #8b0000;
            margin-bottom: 10px;
            font-size: 1.2em;
        }
        .feature-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            position: relative;
        }
        .feature-item {
            background: #fff;
            padding: 8px 12px;
            border-radius: 4px;
            border: 1px solid #ddd;
            cursor: help;
            position: relative;
            transition: all 0.2s ease;
        }
        .feature-item:hover {
            background: #f0f0f0;
            border-color: #8b0000;
        }
        .feature-item::before {
            content: attr(data-tooltip);
            position: fixed;
            bottom: auto;
            left: auto;
            transform: none;
            padding: 8px;
            background: rgba(0, 0, 0, 0.8);
            color: white;
            border-radius: 4px;
            font-size: 0.9em;
            overflow: visible;
            white-space: normal;
            max-width: 300px;
            width: max-content;
            word-wrap: break-word;
            opacity: 0;
            visibility: hidden;
            transition: all 0.2s ease;
            z-index: 1000;
            text-align: left;
            line-height: 1.4;
            pointer-events: none;
        }
        .feature-item:hover::before {
            opacity: 1;
            visibility: visible;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        /* Editable HP fields for DM */
        .hp-editable {
            display: inline-block;
            min-width: 60px;
            border: 1px solid #ddd;
            padding: 2px 6px;
            background: #f9f9f9;
            border-radius: 3px;
            font-family: inherit;
            font-size: inherit;
            text-align: center;
        }
        .hp-editable:focus {
            outline: none;
            border-color: #8b0000;
            background: white;
        }
        .hp-editable:hover {
            border-color: #999;
        }
        .hp-save-btn {
            margin-left: 10px;
            padding: 2px 8px;
            background: #8b0000;
            color: white;
            border: none;
            border-radius: 3px;
            cursor: pointer;
            font-size: 0.9em;
        }
        .hp-save-btn:hover {
            background: #660000;
        }
        .hp-save-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

        /* Action Resource Controls for DM */
        .action-resource-controls {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .action-resource-input {
            width: 60px;
            padding: 3px 6px;
            border: 1px solid #ddd;
            border-radius: 3px;
            text-align: center;
            font-family: inherit;
            font-size: inherit;
        }
        .action-resource-input:focus {
            outline: none;
            border-color: #8b0000;
        }
        .action-resource-buttons {
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .action-resource-btn {
            width: 30px;
            height: 30px;
            border: 1px solid #666;
            background: #f9f9f9;
            border-radius: 3px;
            cursor: pointer;
            font-weight: bold;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }
        .action-resource-btn:hover {
            background: #e9e9e9;
            border-color: #333;
        }
        .action-resource-btn:active {
            background: #d9d9d9;
        }
        .action-resource-btn.minus-btn {
            color: #dc3545;
        }
        .action-resource-btn.plus-btn {
            color: #28a745;
        }
        .action-resource-save-btn {
            padding: 3px 8px;
            background: #8b0000;
            color: white;
            border: none;
            border-radius: 3px;
            cursor: pointer;
            font-size: 0.9em;
            transition: background 0.2s ease;
        }
        .action-resource-save-btn:hover {
            background: #660000;
        }
        .action-resource-save-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
        }
    </style>

</head>
<body data-id="{{ entity.entity_uid }}">
    <div class="sheet">
        <h1>{{ entity.label() }}'s Character Sheet</h1>
        <div class="tab">
            <button class="tablinks" onclick="openTab(event, 'BasicInfo')">Basic Info</button>
            {% if not entity.object() %}
            <button class="tablinks" onclick="openTab(event, 'Spells')">Spells</button>
            <button class="tablinks" onclick="openTab(event, 'Equipment')">Equipment/Inventory</button>
            {% endif %}
        </div>

        <!-- Tab content -->
        <div id="BasicInfo" class="tabcontent">
            <div class="section">
                <div class="section-header">
                    <h2>Basic Information</h2>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content">
                    {% if entity.familiar() %}
                    <h4>{{entity.owner.label()}}'s Familiar</h4>
                    {% endif %}
                    <div class="basic-info-container">
                        <div class="profile-image">
                            <img src="{{ url_for('static', filename='assets/' ~ entity.profile_image()) }}" alt="Profile Image">
                        </div>
                        <div class="description">
                            <p>{{ entity.description() }}</p>
                        </div>
                    </div>
                    <table>
                        {% if not entity.object() and entity.class_and_level() %}
                        <tr>
                            <th>Class & Level</th>
                            {% for class, level in entity.class_and_level() %}
                            {% if level %}
                            <td>Level {{level}} {{ class }}</td>
                            {% else %}
                            <td>{{ class }}</td>
                            {% endif %}
                            {% endfor %}
                        </tr>
                        <tr>
                            <th>Race</th>
                            <td>{{ entity.race() }}</td>
                        </tr>
                        {% endif %}
                    </table>
                </div>
            </div>

            {% if 'dm' in role %}
            <div class="section">
                <div class="section-header">
                    <h2>Controller Assignment</h2>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content">
                    <div class="controller-assignment">
                        <div class="form-group">
                            <label for="controller-input">Assign Controller:</label>
                            <input type="text" id="controller-input" class="form-control" placeholder="Type username to assign...">
                            <div id="controller-suggestions" class="suggestions-list"></div>
                        </div>
                        <div class="current-controllers">
                            <h4>Current Controllers:</h4>
                            <ul id="controllers-list">
                                {% for controller in entity_owners(entity) %}
                                <li>
                                    {{ controller }}
                                    <button class="btn btn-sm btn-danger remove-controller" data-username="{{ controller }}">×</button>
                                </li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            {% endif %}

            {% if not entity.object() %}
            <div class="section">
                <div class="section-header">
                    <h2>Features & Traits</h2>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content">
                    <div class="features-container">
                        {% if entity.properties.get('class_features') %}
                        <div class="feature-section">
                            <h3>Class Features</h3>
                            <ul class="feature-list">
                            {% for feature in entity.properties.get('class_features', []) %}
                                <li class="feature-item" data-tooltip="{{ feature }}">{{ feature | replace('_', ' ') | title }}</li>
                            {% endfor %}
                            </ul>
                        </div>
                        {% endif %}

                        {% if entity.race_properties %}
                        <div class="feature-section">
                            <h3>Race Features</h3>
                            <ul class="feature-list">
                            {% for feature in entity.race_properties.get('race_features', []) %}
                                <li class="feature-item" data-tooltip="{{ t( 'features.' + feature) }}">{{ feature | replace('_', ' ') | title }}</li>
                            {% endfor %}
                            </ul>
                        </div>
                        {% endif %}

                        {% if entity.properties.get('attributes') %}
                        <div class="feature-section">
                            <h3>Other Traits</h3>
                            <ul class="feature-list">
                            {% for feature in entity.properties.get('attributes', []) %}
                                <li class="feature-item" data-tooltip="{{ feature }}">{{ feature | replace('_', ' ') | title }}</li>
                            {% endfor %}
                            </ul>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="section">
                <div class="section-header">
                    <h2>Combat Stats</h2>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content">
                    <h3>Armor Class</h3>
                    <table>
                        <tr>
                            <th>AC</th>
                            {% if entity.equipped_ac()!=entity.armor_class()%}
                            <td>{{ entity.equipped_ac() }} ({{ entity.armor_class() }})</td>
                            {% else %}
                            <td>{{ entity.armor_class() }}</td>
                            {% endif %}
                        </tr>
                    </table>

                    {% if entity.hp() %}
                    <h3>Hit Points</h3>
                    <table>
                        <tr>
                            <th>Max HP</th>
                            <td>
                                {% if 'dm' in role %}
                                <input type="number" class="hp-editable" id="max-hp-input" value="{{ entity.max_hp() }}" min="1" max="999">
                                <button class="hp-save-btn" onclick="updateMaxHP()" id="save-max-hp-btn">Save</button>
                                {% else %}
                                {{ entity.max_hp() }}
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>Current HP</th>
                            <td>
                                {% if 'dm' in role %}
                                <input type="number" class="hp-editable" id="current-hp-input" value="{{ entity.hp() }}" min="0" max="{{ entity.max_hp() }}">
                                <button class="hp-save-btn" onclick="updateCurrentHP()" id="save-current-hp-btn">Save</button>
                                {% else %}
                                {{ entity.hp() }}
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>Temporary HP</th>
                            <td>
                                {% if 'dm' in role %}
                                <input type="number" class="hp-editable" id="temp-hp-input" value="{{ entity.temp_hp() }}" min="0" max="999">
                                <button class="hp-save-btn" onclick="updateTempHP()" id="save-temp-hp-btn">Save</button>
                                {% else %}
                                {{ entity.temp_hp() }}
                                {% endif %}
                            </td>
                        </tr>
                    </table>
                    {% if entity.death_saves > 0 or entity.death_fails > 0 %}
                    <h3>Death Saves</h3>
                    <div class="death-saves">
                        <div class="death-save success">
                            <span class="label">Successes:</span>
                            <span class="value">{{ entity.death_saves }}</span>
                        </div>
                        <div class="death-save fail">
                            <span class="label">Failures:</span>
                            <span class="value">{{ entity.death_fails }}</span>
                        </div>
                    </div>
                    {% endif %}
                    {% endif %}

                    {% if 'dm' in role and battle and battle.entity_state_for(entity) %}
                    <h3>Action Resources (DM Controls)</h3>
                    <p style="font-size: 0.9em; color: #666; margin-bottom: 10px;">
                        <i>Modify action economy during battle. Use +/- buttons for quick adjustments or type values directly.</i>
                    </p>
                    <table>
                        <tr>
                            <th>Actions</th>
                            <td>
                                <div class="action-resource-controls">
                                    <input type="number" class="action-resource-input" id="action-input" value="{{ battle.entity_state_for(entity).get('action', 0) }}" min="0" max="10" title="Current number of actions available">
                                    <div class="action-resource-buttons">
                                        <button class="action-resource-btn minus-btn" onclick="updateActionResource('action', -1)" title="Remove one action">-</button>
                                        <button class="action-resource-btn plus-btn" onclick="updateActionResource('action', 1)" title="Add one action">+</button>
                                        <button class="action-resource-save-btn" onclick="setActionResource('action')" id="save-action-btn" title="Set to the specified value">Set</button>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <th>Bonus Actions</th>
                            <td>
                                <div class="action-resource-controls">
                                    <input type="number" class="action-resource-input" id="bonus-action-input" value="{{ battle.entity_state_for(entity).get('bonus_action', 0) }}" min="0" max="10" title="Current number of bonus actions available">
                                    <div class="action-resource-buttons">
                                        <button class="action-resource-btn minus-btn" onclick="updateActionResource('bonus_action', -1)" title="Remove one bonus action">-</button>
                                        <button class="action-resource-btn plus-btn" onclick="updateActionResource('bonus_action', 1)" title="Add one bonus action">+</button>
                                        <button class="action-resource-save-btn" onclick="setActionResource('bonus_action')" id="save-bonus-action-btn" title="Set to the specified value">Set</button>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <th>Reactions</th>
                            <td>
                                <div class="action-resource-controls">
                                    <input type="number" class="action-resource-input" id="reaction-input" value="{{ battle.entity_state_for(entity).get('reaction', 0) }}" min="0" max="10" title="Current number of reactions available">
                                    <div class="action-resource-buttons">
                                        <button class="action-resource-btn minus-btn" onclick="updateActionResource('reaction', -1)" title="Remove one reaction">-</button>
                                        <button class="action-resource-btn plus-btn" onclick="updateActionResource('reaction', 1)" title="Add one reaction">+</button>
                                        <button class="action-resource-save-btn" onclick="setActionResource('reaction')" id="save-reaction-btn" title="Set to the specified value">Set</button>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    </table>
                    {% endif %}
                </div>
            </div>

            {% if not entity.object() and entity.ability_scores %}
            <div class="section">
                <div class="section-header">
                    <h2>Ability Scores</h2>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content">
                    <table>
                        <tr>
                        <th>Strength</th>
                        <th>Dexterity</th>
                        <th>Constitution</th>
                        <th>Intelligence</th>
                        <th>Wisdom</th>
                        <th>Charisma</th>
                        </tr>
                        <tr>
                        <td class="auto-die-roll" data-entity="{{entity.entity_uid}}" data-compact=true data-roll="1d20{{ entity.str_mod() | mod_str }}" data-description="Strength Check">{{ entity.ability_score_str() }} ({{entity.str_mod() | mod_str}})</td>
                        <td class="auto-die-roll" data-entity="{{entity.entity_uid}}" data-compact=true data-roll="1d20{{ entity.dex_mod() | mod_str }}" data-description="Dexterity Check">{{ entity.ability_score_dex()}} ({{entity.dex_mod() | mod_str }} )</td>
                        <td class="auto-die-roll" data-entity="{{entity.entity_uid}}" data-compact=true data-roll="1d20{{ entity.con_mod() | mod_str }}" data-description="Constitution Check">{{ entity.ability_score_con()}} ({{entity.con_mod() | mod_str }} )</td>
                        <td class="auto-die-roll" data-entity="{{entity.entity_uid}}" data-compact=true data-roll="1d20{{ entity.int_mod() | mod_str }}" data-description="Intelligence Check">{{ entity.ability_score_int() }} ({{entity.int_mod() | mod_str }} )</td>
                        <td class="auto-die-roll" data-entity="{{entity.entity_uid}}" data-compact=true data-roll="1d20{{ entity.wis_mod() | mod_str }}" data-description="Wisdom Check">{{ entity.ability_score_wis() }} ({{entity.wis_mod() | mod_str }} )</td>
                        <td class="auto-die-roll" data-entity="{{entity.entity_uid}}" data-compact=true data-roll="1d20{{ entity.cha_mod() | mod_str }}" data-description="Charisma Check">{{ entity.ability_score_cha() }} ({{entity.cha_mod() | mod_str }} )</td>
                        </tr>
                    </table>

                    {% if entity.resistances or entity.damage_immunities or entity.damage_vulnerabilities or entity.condition_immunities %}
                    <h3>Damage Resistances & Immunities</h3>
                    <table>
                        {% if entity.resistances %}
                        <tr>
                            <th>Resistances</th>
                            <td>{{ entity.effective_resistances() | join(', ') }}</td>
                        </tr>
                        {% endif %}
                        {% if entity.damage_immunities %}
                        <tr>
                            <th>Damage Immunities</th>
                            <td>{{ entity.damage_immunities | join(', ') }}</td>
                        </tr>
                        {% endif %}
                        {% if entity.damage_vulnerabilities %}
                        <tr>
                            <th>Damage Vulnerabilities</th>
                            <td>{{ entity.damage_vulnerabilities | join(', ') }}</td>
                        </tr>
                        {% endif %}
                        {% if entity.condition_immunities %}
                        <tr>
                            <th>Condition Immunities</th>
                            <td>{{ entity.condition_immunities | join(', ') }}</td>
                        </tr>
                        {% endif %}
                    </table>
                    {% endif %}

                    <h3>Saving Throws</h3>
                    <table>
                        <tr>
                            <th>Ability</th>
                            <th>Modifier</th>
                            <th>Proficient</th>
                        </tr>
                        {% for ability in entity.ATTRIBUTE_TYPES %}
                        <tr>
                            <td>{{ ability }}</td>
                            <td class="auto-die-roll" data-entity="{{entity.entity_uid}}" data-compact=true data-roll="1d20{{ entity.saving_throw_mod(ability) | mod_str }}" data-description="{{ability}} save">{{ entity.saving_throw_mod(ability) | mod_str }}</td>
                            <td{% if entity.proficient(ability + "_save") %} style="border: 2px solid black;"{% endif %}>{{ "Yes" if entity.proficient(ability+ "_save") else ""}}</td>
                        </tr>
                        {% endfor %}
                    </table>

                    <h3>Proficiency, Speed and Initiative Bonus</h3>
                    <table>
                        <tr>
                            <th>Proficiency Bonus</th>
                            <th>Initiative</th>
                            <th>Speed</th>
                            {% if 'speed_fly' in entity.properties %}
                            <th>Fly Speed</th>
                            {% endif %}
                        </tr>
                        <tr>
                            <td>+{{ entity.proficiency_bonus() }}</td>
                            <td class="auto-die-roll" data-entity="{{entity.entity_uid}}" data-compact=true data-roll="1d20{{ entity.initiative_bonus() | mod_str }}" data-description="Initiative">+{{ entity.initiative_bonus() }}</td>
                            {% if entity.speed() != entity.properties.get('speed', 0) %}
                            <td>{{ entity.speed() }} + {{ entity.speed() - entity.properties.get('speed', 0) }}) ft.</td>
                            {% else %}
                            <td>{{ entity.properties.get('speed', 0) }} ft.</td>
                            {% endif %}

                            {% if 'speed_fly' in entity.properties %}
                                <td>{{ entity.properties.get('speed_fly', 0) }} ft.</td>
                            {% endif %}
                        </tr>
                    </table>

                    <h3>Passive Scores</h3>
                    <table>
                        <tr>
                            <th>Passive Perception</th>
                            <th>Passive Investigation</th>
                            <th>Passive Insight</th>
                        </tr>
                        <tr>
                            <td>{{ entity.passive_perception() }}</td>
                            <td>{{ entity.passive_investigation() }}</td>
                            <td>{{ entity.passive_insight() }}</td>
                        </tr>
                    </table>

                    <h3>Skills</h3>
                    <table>
                        <tr>
                            <th>Skill</th>
                            <th>Modifier</th>
                            <th>Proficient</th>
                        </tr>
                        {% for ability, skills in entity.SKILL_AND_ABILITY_MAP.items() %}
                        {% for skill in skills %}
                        <tr>
                            <td>{{ skill }}</td>
                            <td class="auto-die-roll" data-entity="{{entity.entity_uid}}" data-compact=true data-roll="1d20{{ entity[skill + '_mod']() | mod_str }}" data-description="{{skill}} check">{{ entity[skill + "_mod"]() | mod_str }}</td>
                            <td{% if entity.proficient(skill) %} style="border: 2px solid black;"{% endif %}>{{ "Yes" if entity.proficient(skill) else ""}}</td>
                        </tr>
                        {% endfor %}
                        {% endfor %}
                    </table>
                </div>
            </div>
            {% endif %}
        </div>

        {% if not entity.object() %}
        <div id="Spells" class="tabcontent">
            <h2>Spells</h2>
            <!-- Spells section -->
            {% for klass, level in entity.class_and_level() %}
            <div class="section">
                <div class="section-header">
                    <h3>{{ klass }} Spells</h3>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content">
                    {% set spells_per_level = entity.available_spells_per_level(battle) %}
                    
                    {% for level, level_spells in spells_per_level %}
                    {% if level_spells %}
                    <div class="spell-level">
                        {% if level == 0 %}
                        <div class="spell-level-header">Cantrips</div>
                        {% else %}
                        <div class="spell-level-header">
                            Level {{ level }} - 
                            {% if 'dm' in role %}
                                <span class="editable-spell-slots" data-entity-id="{{ entity.entity_uid }}" data-class="{{ klass }}" data-level="{{ level }}">
                                    <button class="btn btn-sm btn-outline-secondary" onclick="adjustSpellSlots('{{ entity.entity_uid }}', '{{ klass }}', {{ level }}, 'subtract', 1)">-</button>
                                    <input type="number" min="0" max="{{ entity.max_spell_slots(level, klass) }}" 
                                           value="{{ entity.spell_slots_count(level, klass) }}" 
                                           class="spell-slot-input form-control d-inline" 
                                           style="width: 60px; display: inline-block; text-align: center; margin: 0 5px;"
                                           data-entity-id="{{ entity.entity_uid }}" data-class="{{ klass }}" data-level="{{ level }}"
                                           onchange="updateSpellSlots('{{ entity.entity_uid }}', '{{ klass }}', {{ level }}, this.value)">
                                    <button class="btn btn-sm btn-outline-secondary" onclick="adjustSpellSlots('{{ entity.entity_uid }}', '{{ klass }}', {{ level }}, 'add', 1)">+</button>
                                    /{{ entity.max_spell_slots(level, klass) }} Slots
                                </span>
                            {% else %}
                                {{ entity.spell_slots_count(level, klass) }}/{{ entity.max_spell_slots(level, klass) }} Slots
                            {% endif %}
                        </div>
                        {% endif %}
                        <div class="spells-container-sheet">
                            {% for name, details in level_spells %}
                             <div class="spell" role="button" aria-pressed="false">
                                <div class="spell-inner">
                                    <div class="spell-front">
                                        <img src="{{ url_for('static', filename='spells/spell_' + name + '.png') }}" alt="{{ name }}" class="spell-icon-sheet">
                                        <div class="spell-label">{{ details['label'] }}</div>
                                        <table class="spell-details-table">
                                            <tr>
                                                <td class="spell-details-name"><i class="fas fa-hourglass-start"></i> <strong>Casting Time</strong></td>
                                                <td>{{ details['casting_time'] | casting_time }}</td>
                                            </tr>
                                            <tr>
                                                <td class="spell-details-name"><i class="fas fa-bullseye"></i> <strong>Range</strong></td>
                                                <td>{{ details['range'] }}</td>
                                            </tr>
                                        </table>
                                    </div>
                                    <div class="spell-back">
                                        <div class="spell-description">
                                            {{ details['description'] }}
                                        </div>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </div>

        {% if entity.inventory %}
        <div id="Equipment" class="tabcontent">
            <div class="section">
                <div class="section-header">
                    <h2>Equipment</h2>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content equipment-container">
                    {% include 'equipment.html' %}
                </div>
            </div>

            <div class="section">
                <div class="section-header">
                    <h2>Potions/Consumables</h2>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content">
                    <ul class="consumables-list tile-inventory">
                    {% for item in entity.usable_items() %}
                    <li class="tile-item" data-tooltip="{{ item['label'] }}">
                    <div class="item-icon-container">
                        <img class="item-icon" src="{{ item.get('icon', '/assets/items/' ~ item['image'] ~ '.png') }}" alt="{{ item['label'] }}">
                        <div class="item-quantity">{{ 'x ' ~ item.get('qty', 1) }}</div>
                    </div>
                    </li>
                    {% endfor %}
                    </ul>
                </div>
            </div>

            <div class="section">
                <div class="section-header">
                    <h2>Other Items</h2>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content">
                    <ul class="consumables-list tile-inventory">
                    {% for item in entity.other_items() %}
                    <li class="tile-item" data-tooltip="{{ item['label'] }}">
                    <div class="item-icon-container">
                        <img class="item-icon" src="{{ item.get('icon', '/assets/items/' ~ item['image'] ~ '.png') }}" alt="{{ item['label'] }}">
                        <div class="item-quantity">{{ 'x ' ~ item.get('qty', 1) }}</div>
                        {% if item['type'] == 'letter' %}
                        <form method="post" action="/read_letter" target="_blank">
                            <input type="hidden" name="id" value="{{ entity.entity_uid }}">
                            <input type="hidden" name="item_id" value="{{ item['name'] }}">
                            <button>Read</button>
                        </form>
                        {% endif %}
                    </div>
                    </li>
                    {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
        {% endif %}
        {% endif %}
    </div>
    <script src="/sheet.js?salt={{ salt }}"></script>
    <script src="/utils.js?salt={{ salt }}"></script>
    <script>
        // HP Update Functions for DM
        function updateMaxHP() {
            const input = document.getElementById('max-hp-input');
            const button = document.getElementById('save-max-hp-btn');
            const value = parseInt(input.value);
            
            if (isNaN(value) || value < 1) {
                alert('Max HP must be a positive number');
                return;
            }
            
            button.disabled = true;
            button.textContent = 'Saving...';
            
            fetch('/update_hp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    entity_id: document.body.dataset.id,
                    hp_type: 'max_hp',
                    value: value
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    button.textContent = 'Saved!';
                    setTimeout(() => {
                        button.textContent = 'Save';
                        button.disabled = false;
                    }, 1000);
                    // Update current HP max constraint
                    const currentHPInput = document.getElementById('current-hp-input');
                    if (currentHPInput) {
                        currentHPInput.max = value;
                    }
                } else {
                    alert('Failed to update Max HP: ' + (data.error || 'Unknown error'));
                    button.textContent = 'Save';
                    button.disabled = false;
                }
            })
            .catch(error => {
                alert('Error updating Max HP: ' + error);
                button.textContent = 'Save';
                button.disabled = false;
            });
        }
        
        function updateCurrentHP() {
            const input = document.getElementById('current-hp-input');
            const button = document.getElementById('save-current-hp-btn');
            const value = parseInt(input.value);
            const maxHP = parseInt(document.getElementById('max-hp-input')?.value || input.max);
            
            if (isNaN(value) || value < 0) {
                alert('Current HP must be 0 or greater');
                return;
            }
            
            if (value > maxHP) {
                alert('Current HP cannot exceed Max HP (' + maxHP + ')');
                return;
            }
            
            button.disabled = true;
            button.textContent = 'Saving...';
            
            fetch('/update_hp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    entity_id: document.body.dataset.id,
                    hp_type: 'current_hp',
                    value: value
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    button.textContent = 'Saved!';
                    setTimeout(() => {
                        button.textContent = 'Save';
                        button.disabled = false;
                    }, 1000);
                } else {
                    alert('Failed to update Current HP: ' + (data.error || 'Unknown error'));
                    button.textContent = 'Save';
                    button.disabled = false;
                }
            })
            .catch(error => {
                alert('Error updating Current HP: ' + error);
                button.textContent = 'Save';
                button.disabled = false;
            });
        }
        
        function updateTempHP() {
            const input = document.getElementById('temp-hp-input');
            const button = document.getElementById('save-temp-hp-btn');
            const value = parseInt(input.value);
            
            if (isNaN(value) || value < 0) {
                alert('Temporary HP must be 0 or greater');
                return;
            }
            
            button.disabled = true;
            button.textContent = 'Saving...';
            
            fetch('/update_hp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    entity_id: document.body.dataset.id,
                    hp_type: 'temp_hp',
                    value: value
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    button.textContent = 'Saved!';
                    setTimeout(() => {
                        button.textContent = 'Save';
                        button.disabled = false;
                    }, 1000);
                } else {
                    alert('Failed to update Temporary HP: ' + (data.error || 'Unknown error'));
                    button.textContent = 'Save';
                    button.disabled = false;
                }
            })
            .catch(error => {
                alert('Error updating Temporary HP: ' + error);
                button.textContent = 'Save';
                button.disabled = false;
            });
        }

        // Action Resource Update Functions for DM
        function updateActionResource(resourceType, change) {
            const input = document.getElementById(resourceType.replace('_', '-') + '-input');
            const currentValue = parseInt(input.value) || 0;
            const newValue = Math.max(0, Math.min(10, currentValue + change));
            input.value = newValue;
            
            // Auto-save the change
            setActionResource(resourceType);
        }
        
        function setActionResource(resourceType) {
            const input = document.getElementById(resourceType.replace('_', '-') + '-input');
            const button = document.getElementById('save-' + resourceType.replace('_', '-') + '-btn');
            const value = parseInt(input.value);
            
            if (isNaN(value) || value < 0) {
                alert('Resource value must be 0 or greater');
                return;
            }
            
            button.disabled = true;
            button.textContent = 'Saving...';
            
            fetch('/update_action_resources', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    entity_id: document.body.dataset.id,
                    resource_type: resourceType,
                    value: value,
                    operation: 'set'
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    button.textContent = 'Saved!';
                    setTimeout(() => {
                        button.textContent = 'Set';
                        button.disabled = false;
                    }, 1000);
                } else {
                    alert('Failed to update ' + resourceType.replace('_', ' ') + ': ' + (data.error || 'Unknown error'));
                    button.textContent = 'Set';
                    button.disabled = false;
                }
            })
            .catch(error => {
                alert('Error updating ' + resourceType.replace('_', ' ') + ': ' + error);
                button.textContent = 'Set';
                button.disabled = false;
            });
        }

        // Spell Slot Update Functions for DM
        function updateSpellSlots(entityId, characterClass, level, value) {
            const input = document.querySelector(`input[data-entity-id="${entityId}"][data-class="${characterClass}"][data-level="${level}"]`);
            if (!input) return;
            
            const numValue = parseInt(value);
            const maxValue = parseInt(input.max);
            
            if (isNaN(numValue) || numValue < 0) {
                alert('Spell slot value must be 0 or greater');
                input.value = input.defaultValue; // Reset to previous value
                return;
            }
            
            if (numValue > maxValue) {
                alert(`Spell slots cannot exceed maximum (${maxValue})`);
                input.value = maxValue;
                return;
            }
            
            fetch('/update_spell_slots', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    entity_id: entityId,
                    character_class: characterClass,
                    level: parseInt(level),
                    value: numValue,
                    operation: 'set'
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Update the input value to reflect the actual saved value
                    input.value = data.new_value;
                    input.defaultValue = data.new_value;
                    
                    // Show brief success feedback
                    const originalBg = input.style.backgroundColor;
                    input.style.backgroundColor = '#d4edda';
                    setTimeout(() => {
                        input.style.backgroundColor = originalBg;
                    }, 1000);
                } else {
                    alert('Failed to update spell slots: ' + (data.error || 'Unknown error'));
                    input.value = input.defaultValue; // Reset to previous value
                }
            })
            .catch(error => {
                alert('Error updating spell slots: ' + error);
                input.value = input.defaultValue; // Reset to previous value
            });
        }
        
        function adjustSpellSlots(entityId, characterClass, level, operation, amount) {
            const input = document.querySelector(`input[data-entity-id="${entityId}"][data-class="${characterClass}"][data-level="${level}"]`);
            if (!input) return;
            
            const currentValue = parseInt(input.value) || 0;
            const maxValue = parseInt(input.max);
            let newValue;
            
            if (operation === 'add') {
                newValue = Math.min(currentValue + amount, maxValue);
            } else if (operation === 'subtract') {
                newValue = Math.max(currentValue - amount, 0);
            } else {
                return;
            }
            
            if (newValue === currentValue) {
                return; // No change needed
            }
            
            fetch('/update_spell_slots', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    entity_id: entityId,
                    character_class: characterClass,
                    level: parseInt(level),
                    value: newValue,
                    operation: 'set'
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Update the input value to reflect the actual saved value
                    input.value = data.new_value;
                    input.defaultValue = data.new_value;
                    
                    // Show brief success feedback
                    const originalBg = input.style.backgroundColor;
                    input.style.backgroundColor = '#d4edda';
                    setTimeout(() => {
                        input.style.backgroundColor = originalBg;
                    }, 1000);
                } else {
                    alert('Failed to update spell slots: ' + (data.error || 'Unknown error'));
                }
            })
            .catch(error => {
                alert('Error updating spell slots: ' + error);
            });
        }

        // Add Enter key support for HP inputs
        document.addEventListener('DOMContentLoaded', function() {
            const maxHPInput = document.getElementById('max-hp-input');
            const currentHPInput = document.getElementById('current-hp-input');
            const tempHPInput = document.getElementById('temp-hp-input');
            
            // Action resource inputs
            const actionInput = document.getElementById('action-input');
            const bonusActionInput = document.getElementById('bonus-action-input');
            const reactionInput = document.getElementById('reaction-input');
            
            if (maxHPInput) {
                maxHPInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        updateMaxHP();
                    }
                });
            }
            
            if (currentHPInput) {
                currentHPInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        updateCurrentHP();
                    }
                });
            }
            
            if (tempHPInput) {
                tempHPInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        updateTempHP();
                    }
                });
            }
            
            if (actionInput) {
                actionInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        setActionResource('action');
                    }
                });
            }
            
            if (bonusActionInput) {
                bonusActionInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        setActionResource('bonus_action');
                    }
                });
            }
            
            if (reactionInput) {
                reactionInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        setActionResource('reaction');
                    }
                });
            }
            
            // Add Enter key support for spell slot inputs
            const spellSlotInputs = document.querySelectorAll('.spell-slot-input');
            spellSlotInputs.forEach(input => {
                input.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        const entityId = this.dataset.entityId;
                        const characterClass = this.dataset.class;
                        const level = this.dataset.level;
                        updateSpellSlots(entityId, characterClass, level, this.value);
                    }
                });
                
                // Store the default value for reset purposes
                input.defaultValue = input.value;
            });
        });
    </script>
    <script>
        // Add collapsible section functionality
        document.addEventListener('DOMContentLoaded', function() {
            const sections = document.querySelectorAll('.section');
            
            sections.forEach(section => {
                const header = section.querySelector('.section-header');
                const content = section.querySelector('.section-content');
                
                // Set initial state
                content.classList.remove('collapsed');
                header.classList.remove('collapsed');
                
                header.addEventListener('click', () => {
                    content.classList.toggle('collapsed');
                    header.classList.toggle('collapsed');
                });
            });
        });
    </script>
</body>
</html>
