<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>D&D Character Sheet</title>
    <link rel="stylesheet" href="/libs/font-awesome/css/all.min.css">
    <link href="{{ asset_url('styles.css') }}" rel="stylesheet">
    <link href="{{ asset_url('sheet.css') }}" rel="stylesheet">
    
    <link href="https://fonts.googleapis.com/css?family=Cinzel|Uncial+Antiqua|IM+Fell+English" rel="stylesheet">
    <script src="/libs/jquery/jquery-3.6.0.min.js"></script>
    <style>
        body {
            font-family: 'Times New Roman', serif;
            background: beige;
            padding: 20px;
        }
        .sheet {
            background: white;
            max-width: 800px;
            margin: auto;
            padding: 20px;
            border: 1px solid #ccc;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        h1, h2, h3 {
            color: darkred;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            border: 1px solid black;
            padding: 8px;
            text-align: left;
        }
        th {
            background-color: #f2f2f2;
        }
        /* Tab Styling */
        .tab {
            overflow: hidden;
            border: 1px solid #ccc;
            background-color: #f1f1f1;
        }
        .tab button {
            background-color: inherit;
            float: left;
            border: none;
            outline: none;
            cursor: pointer;
            padding: 14px 16px;
            transition: 0.3s;
            font-size: 17px;
        }
        .tab button:hover {
            background-color: #ddd;
        }
        .tab button.active {
            background-color: #ccc;
        }
        .tabcontent {
            display: none;
            padding: 6px 12px;
            border: 1px solid #ccc;
            border-top: none;
        }

        /* Features & Traits Styling */
        .features-container {
            margin: 20px 0;
            padding: 15px;
            background: #f9f9f9;
            border-radius: 5px;
        }
        .feature-section {
            margin-bottom: 20px;
        }
        .feature-section h3 {
            color: #8b0000;
            margin-bottom: 10px;
            font-size: 1.2em;
        }
        .feature-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            position: relative;
        }
        .feature-item {
            background: #fff;
            padding: 8px 12px;
            border-radius: 4px;
            border: 1px solid #ddd;
            cursor: help;
            position: relative;
            transition: all 0.2s ease;
        }
        .feature-item:hover {
            background: #f0f0f0;
            border-color: #8b0000;
        }
        .feature-item::before {
            content: attr(data-tooltip);
            position: fixed;
            bottom: auto;
            left: auto;
            transform: none;
            padding: 8px;
            background: rgba(0, 0, 0, 0.8);
            color: white;
            border-radius: 4px;
            font-size: 0.9em;
            overflow: visible;
            white-space: normal;
            max-width: 300px;
            width: max-content;
            word-wrap: break-word;
            opacity: 0;
            visibility: hidden;
            transition: all 0.2s ease;
            z-index: 1000;
            text-align: left;
            line-height: 1.4;
            pointer-events: none;
        }
        .feature-item:hover::before {
            opacity: 1;
            visibility: visible;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        /* Editable HP fields for DM */
        .hp-editable {
            display: inline-block;
            min-width: 60px;
            border: 1px solid #ddd;
            padding: 2px 6px;
            background: #f9f9f9;
            border-radius: 3px;
            font-family: inherit;
            font-size: inherit;
            text-align: center;
        }
        .hp-editable:focus {
            outline: none;
            border-color: #8b0000;
            background: white;
        }
        .hp-editable:hover {
            border-color: #999;
        }
        .hp-save-btn {
            margin-left: 10px;
            padding: 2px 8px;
            background: #8b0000;
            color: white;
            border: none;
            border-radius: 3px;
            cursor: pointer;
            font-size: 0.9em;
        }
        .hp-save-btn:hover {
            background: #660000;
        }
        .hp-save-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

        /* Action Resource Controls for DM */
        .action-resource-controls {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .action-resource-input {
            width: 60px;
            padding: 3px 6px;
            border: 1px solid #ddd;
            border-radius: 3px;
            text-align: center;
            font-family: inherit;
            font-size: inherit;
        }
        .action-resource-input:focus {
            outline: none;
            border-color: #8b0000;
        }
        .action-resource-buttons {
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .action-resource-btn {
            width: 30px;
            height: 30px;
            border: 1px solid #666;
            background: #f9f9f9;
            border-radius: 3px;
            cursor: pointer;
            font-weight: bold;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }
        .action-resource-btn:hover {
            background: #e9e9e9;
            border-color: #333;
        }
        .action-resource-btn:active {
            background: #d9d9d9;
        }
        .action-resource-btn.minus-btn {
            color: #dc3545;
        }
        .action-resource-btn.plus-btn {
            color: #28a745;
        }
        .action-resource-save-btn {
            padding: 3px 8px;
            background: #8b0000;
            color: white;
            border: none;
            border-radius: 3px;
            cursor: pointer;
            font-size: 0.9em;
            transition: background 0.2s ease;
        }
        .action-resource-save-btn:hover {
            background: #660000;
        }
        .action-resource-save-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
        }
    </style>

</head>
<body data-id="{{ entity.entity_uid }}">
    <div class="sheet">
        <h1>{{ entity.label() }}'s Character Sheet</h1>
        <div class="tab">
            <button class="tablinks" onclick="openTab(event, 'BasicInfo')">Basic Info</button>
            {% if not entity.object() %}
            <button class="tablinks" onclick="openTab(event, 'Spells')">Spells</button>
            <button class="tablinks" onclick="openTab(event, 'Equipment')">Equipment/Inventory</button>
            {% if entity.__class__.__name__ == 'PlayerCharacter' %}
            <button class="tablinks" onclick="openTab(event, 'Journal')">Journal</button>
            {% endif %}
            {% endif %}
        </div>

        <!-- Tab content -->
        <div id="BasicInfo" class="tabcontent">
            <div class="section">
                <div class="section-header">
                    <h2>Basic Information</h2>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content">
                    {% if entity.familiar() %}
                    <h4>{{entity.owner.label()}}'s Familiar</h4>
                    {% endif %}
                    <div class="basic-info-container">
                        <div class="profile-image">
                            <img src="{{ url_for('static', filename='assets/' ~ entity.profile_image()) }}" alt="Profile Image">
                        </div>
                        <div class="description">
                            <p>{{ entity.description() }}</p>
                        </div>
                    </div>
                    <table>
                        {% if not entity.object() and entity.class_and_level() %}
                        <tr>
                            <th>Class & Level</th>
                            {% for class, level in entity.class_and_level() %}
                            {% if level %}
                            <td>Level {{level}} {{ class }}</td>
                            {% else %}
                            <td>{{ class }}</td>
                            {% endif %}
                            {% endfor %}
                        </tr>
                        <tr>
                            <th>Race</th>
                            <td>{{ entity.race() }}</td>
                        </tr>
                        {% set languages_display = format_languages(entity) %}
                        {% if languages_display %}
                        <tr>
                            <th>Languages</th>
                            <td>{{ languages_display }}</td>
                        </tr>
                        {% endif %}
                        {% endif %}
                    </table>
                </div>
            </div>

            {% if 'dm' in role %}
            <div class="section">
                <div class="section-header">
                    <h2>Controller Assignment</h2>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content">
                    <div class="controller-assignment">
                        <div class="form-group">
                            <label for="controller-input">Assign Controller:</label>
                            <input type="text" id="controller-input" class="form-control" placeholder="Type username to assign...">
                            <div id="controller-suggestions" class="suggestions-list"></div>
                        </div>
                        <div class="form-group">
                            <label for="controller-select">Or Select User:</label>
                            <select id="controller-select" class="form-control">
                                <option value="">-- Select --</option>
                                {% for user in all_users %}
                                <option value="{{ user }}">{{ user }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="current-controllers">
                            <h4>Current Controllers:</h4>
                            <ul id="controllers-list">
                                {% for controller in entity_owners(entity) %}
                                <li>
                                    {{ controller }}
                                    <button class="btn btn-sm btn-danger remove-controller" data-username="{{ controller }}">×</button>
                                </li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            {% if entity.is_npc() %}
            <div class="section">
                <div class="section-header">
                    <h2>NPC Customization</h2>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content">
                    <div class="npc-customization">
                        <div class="form-group">
                            <label for="npc-name">Display Name:</label>
                            <input type="text" id="npc-name" class="form-control" 
                                   value="{{ entity.label() }}" 
                                   placeholder="Enter custom name...">
                        </div>
                        
                        <div class="form-group">
                            <label for="npc-group">Group/Faction:</label>
                            <select id="npc-group" class="form-control">
                                <option value="a" {% if entity.group == 'a' %}selected{% endif %}>Group A - Allies of PCs</option>
                                <option value="b" {% if entity.group == 'b' %}selected{% endif %}>Group B - Enemies of PCs</option>
                                <option value="c" {% if entity.group == 'c' %}selected{% endif %}>Group C - Neutral</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="npc-description">Description:</label>
                            <textarea id="npc-description" class="form-control" rows="3" 
                                      placeholder="Enter character description...">{{ entity.description() }}</textarea>
                        </div>
                        
                        <div class="form-group">
                            <label for="npc-backstory">Backstory:</label>
                            <textarea id="npc-backstory" class="form-control" rows="4" 
                                      placeholder="Enter character backstory...">{{ entity.properties.get('backstory', '') }}</textarea>
                        </div>
                        
                        <div class="form-group">
                            <button id="save-npc-changes" class="btn btn-primary">Save Changes</button>
                            <button id="reset-npc-changes" class="btn btn-secondary">Reset</button>
                        </div>
                    </div>
                </div>
            </div>
            {% endif %}
            {% endif %}

            {% if not entity.object() %}
            <div class="section">
                <div class="section-header">
                    <h2>Features & Traits</h2>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content">
                    <div class="features-container">
                        {% if entity.properties.get('class_features') %}
                        <div class="feature-section">
                            <h3>Class Features</h3>
                            <ul class="feature-list">
                            {% for feature in entity.properties.get('class_features', []) %}
                                <li class="feature-item" data-tooltip="{{ feature }}">{{ feature | replace('_', ' ') | title }}</li>
                            {% endfor %}
                            </ul>
                        </div>
                        {% endif %}

                        {% if entity.race_properties %}
                        <div class="feature-section">
                            <h3>Race Features</h3>
                            <ul class="feature-list">
                            {% for feature in entity.race_properties.get('race_features', []) %}
                                <li class="feature-item" data-tooltip="{{ t( 'features.' + feature) }}">{{ feature | replace('_', ' ') | title }}</li>
                            {% endfor %}
                            </ul>
                        </div>
                        {% endif %}

                        {% if entity.properties.get('attributes') %}
                        <div class="feature-section">
                            <h3>Other Traits</h3>
                            <ul class="feature-list">
                            {% for feature in entity.properties.get('attributes', []) %}
                                <li class="feature-item" data-tooltip="{{ feature }}">{{ feature | replace('_', ' ') | title }}</li>
                            {% endfor %}
                            </ul>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="section">
                <div class="section-header">
                    <h2>Combat Stats</h2>
                    <i class="fas fa-chevron-down toggle-icon"></i>
                </div>
                <div class="section-content">
                    <h3>Armor Class</h3>
                    <table>
                        <tr>
                            <th>AC</th>
                            {% if entity.equipped_ac()!=entity.armor_class()%}
                            <td>{{ entity.equipped_ac() }} ({{ entity.armor_class() }})</td>
                            {% else %}
                            <td>{{ entity.armor_class() }}</td>
                            {% endif %}
                        </tr>
                    </table>

                    {% if entity.hp() %}
                    <h3>Hit Points</h3>
                    <table>
                        <tr>
                            <th>Max HP</th>
                            <td>
                                {% if 'dm' in role %}
                                <input type="number" class="hp-editable" id="max-hp-input" value="{{ entity.max_hp() }}" min="1" max="999">
                                <button class="hp-save-btn" onclick="updateMaxHP()" id="save-max-hp-btn">Save</button>
                                {% else %}
                                {{ entity.max_hp() }}
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>Current HP</th>
                            <td>
                                {% if 'dm' in role %}
                                <input type="number" class="hp-editable" id="current-hp-input" value="{{ entity.hp() }}" min="0" max="{{ entity.max_hp() }}">
                                <button class="hp-save-btn" onclick="updateCurrentHP()" id="save-current-hp-btn">Save</button>
                                {% else %}
                                {{ entity.hp() }}
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>Temporary HP</th>
                            <td>
                                {% if 'dm' in role %}
                                <input type="number" class="hp-editable" id="temp-hp-input" value="{{ entity.temp_hp() }}" min="0" max="999">
                                <button class="hp-save-btn" onclick="updateTempHP()" id="save-temp-hp-btn">Save</button>
                                {% else %}
                                {{ entity.temp_hp() }}
                                {% endif %}
                            </td>
                        </tr>
                    </table>
                    {% if not restricted and can_rest_for(entity.entity_uid) %}
                    <div class="rest-controls" style="margin: 8px 0 12px 0;">
                        <div style="display: flex; gap: 6px; align-items: center; flex-wrap: wrap;">
                            <button type="button" class="hp-save-btn" id="rest-btn-short"
                                data-rest-entity="{{ entity.entity_uid }}" data-rest-type="short"
                                onclick="openRestModal('{{ entity.entity_uid }}', 'short')">Short Rest</button>
                            <button type="button" class="hp-save-btn" id="rest-btn-long"
                                data-rest-entity="{{ entity.entity_uid }}" data-rest-type="long"
                                onclick="openRestModal('{{ entity.entity_uid }}', 'long')">Long Rest</button>
                            <span id="rest-status-indicator" style="font-size: 12px; color: #b00;"></span>
                        </div>
                        <div id="rest-status-detail" style="font-size: 12px; color: #666; margin-top: 4px;"></div>
                    </div>
                    {% endif %}
                    {% if entity.death_saves > 0 or entity.death_fails > 0 %}
                    <h3>Death Saves</h3>
                    <div class="death-saves">
                        <div class="death-save success">
                            <span class="label">Successes:</span>
                            <span class="value">{{ entity.death_saves }}</span>
                        </div>
                        <div class="death-save fail">
                            <span class="label">Failures:</span>
                            <span class="value">{{ entity.death_fails }}</span>
                        </div>
                    </div>
                    {% endif %}
                    {% endif %}

                    {# Class-feature resources (ki, rage, second wind, etc.) #}
                    {% set _has_ki = entity.max_ki|default(0) %}
                    {% set _has_rage = entity.rage_max|default(0) %}
                    {% set _has_sw = entity.second_wind_count is defined and entity.second_wind_count is not none %}
                    {% set _has_loh = entity.lay_on_hands_count is defined and entity.lay_on_hands_count is not none %}
                    {% set _has_bardic = entity.bardic_inspiration_max|default(0) %}
                    {% set _has_wild = entity.wild_shape_max|default(0) %}
                    {% set _has_arcane = entity.arcane_recovery is defined and entity.arcane_recovery is not none %}
                    {% if _has_ki or _has_rage or _has_sw or _has_loh or _has_bardic or _has_wild or _has_arcane %}
                    <h3>Class Resources</h3>
                    <table class="class-resources-table">
                        {% if _has_ki %}
                        <tr>
                            <th>Ki Points</th>
                            <td>
                                <span class="resource-value">{{ entity.ki_count or 0 }}/{{ entity.max_ki }}</span>
                                <div class="resource-pips" aria-hidden="true">
                                    {% for i in range(entity.max_ki) %}
                                    <span class="pip {{ 'filled' if i < (entity.ki_count or 0) else 'empty' }}" title="Ki point"></span>
                                    {% endfor %}
                                </div>
                            </td>
                        </tr>
                        {% endif %}
                        {% if _has_rage %}
                        <tr>
                            <th>Rage Uses</th>
                            <td>
                                <span class="resource-value">{{ entity.rage_count or 0 }}/{{ entity.rage_max }}</span>
                                {% if entity.is_raging() %}
                                <span class="badge badge-danger" style="background:#c0392b;color:#fff;padding:2px 6px;border-radius:4px;margin-left:6px;">Raging ({{ entity.rage_rounds_remaining }} rd)</span>
                                {% endif %}
                                {% if entity.is_reckless() %}
                                <span class="badge" style="background:#e67e22;color:#fff;padding:2px 6px;border-radius:4px;margin-left:6px;">Reckless</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endif %}
                        {% if _has_sw %}
                        <tr>
                            <th>Second Wind</th>
                            <td><span class="resource-value">{{ entity.second_wind_count }}/1</span></td>
                        </tr>
                        {% endif %}
                        {% if _has_loh %}
                        <tr>
                            <th>Lay on Hands</th>
                            <td><span class="resource-value">{{ entity.lay_on_hands_count }} HP</span></td>
                        </tr>
                        {% endif %}
                        {% if _has_bardic %}
                        <tr>
                            <th>Bardic Inspiration</th>
                            <td><span class="resource-value">{{ entity.bardic_inspiration_count or 0 }}/{{ entity.bardic_inspiration_max }}</span></td>
                        </tr>
                        {% endif %}
                        {% if _has_wild %}
                        <tr>
                            <th>Wild Shape</th>
                            <td><span class="resource-value">{{ entity.wild_shape_count or 0 }}/{{ entity.wild_shape_max }}</span></td>
                        </tr>
                        {% endif %}
                        {% if _has_arcane %}
                        <tr>
                            <th>Arcane Recovery</th>
                            <td><span class="resource-value">{{ 'Available' if entity.arcane_recovery else 'Used' }}</span></td>
                        </tr>
                        {% endif %}
                    </table>
                    <style>
                        .class-resources-table .resource-value{font-weight:600}
                        .class-resources-table .resource-pips{display:inline-flex;gap:3px;margin-left:8px;vertical-align:middle}
                        .class-resources-table .pip{display:inline-block;width:10px;height:10px;border-radius:50%;border:1px solid #555}
                        .class-resources-table .pip.filled{background:#f1c40f;border-color:#b07d00;box-shadow:0 0 3px rgba(241,196,15,0.7)}
                        .class-resources-table .pip.empty{background:#333}
                    </style>
                    {% endif %}

                    {# Unarmed Strike summary (always available to PCs) #}
                    {% set _unarmed = entity.unarmed_strike_info() if entity.unarmed_strike_info is defined else none %}
                    {% if _unarmed %}
                    <h3>Unarmed Strike</h3>
                    <table class="unarmed-strike-table">
                        <tr>
                            <th>Attack</th>
                            <td>
                                <span class="unarmed-bonus">{{ '+' if _unarmed.attack_bonus >= 0 else '' }}{{ _unarmed.attack_bonus }}</span>
                                <span class="unarmed-ability">({{ _unarmed.ability }})</span>
                            </td>
                        </tr>
                        <tr>
                            <th>Damage</th>
                            <td>
                                <span class="unarmed-damage">{{ _unarmed.damage }}</span>
                                <span class="unarmed-damage-type">{{ _unarmed.damage_type }}</span>
                            </td>
                        </tr>
                        <tr>
                            <th>Range</th>
                            <td>{{ _unarmed.range }} ft</td>
                        </tr>
                        {% if _unarmed.properties %}
                        <tr>
                            <th>Properties</th>
                            <td>
                                {% for prop in _unarmed.properties %}
                                <span class="badge" style="background:#34495e;color:#fff;padding:2px 6px;border-radius:4px;margin-right:4px;">{{ prop }}</span>
                                {% endfor %}
                            </td>
                        </tr>
                        {% endif %}
                    </table>
                    <style>
                        .unarmed-strike-table .unarmed-bonus{font-weight:700;font-size:1.05em}
                        .unarmed-strike-table .unarmed-ability{color:#888;margin-left:4px;font-size:0.9em}
                        .unarmed-strike-table .unarmed-damage{font-weight:600}
                        .unarmed-strike-table .unarmed-damage-type{color:#888;margin-left:4px;font-size:0.9em;text-transform:capitalize}
                    </style>
                    {% endif %}

                    {% if 'dm' in role and battle and battle.entity_state_for(entity) %}
                    <h3>Action Resources (DM Controls)</h3>
                    <p style="font-size: 0.9em; color: #666; margin-bottom: 10px;">
                        <i>Modify action economy during battle. Use +/- buttons for quick adjustments or type values directly.</i>
                    </p>
                    <table>
                        <tr>
                            <th>Actions</th>
                            <td>
                                <div class="action-resource-controls">
                                    <input type="number" class="action-resource-input" id="action-input" value="{{ battle.entity_state_for(entity).get('action', 0) }}" min="0" max="10" title="Current number of actions available">
                                    <div class="action-resource-buttons">
                                        <button class="action-resource-btn minus-btn" onclick="updateActionResource('action', -1)" title="Remove one action">-</button>
                                        <button class="action-resource-btn plus-btn" onclick="updateActionResource('action', 1)" title="Add one action">+</button>
                                        <button class="action-resource-save-btn" onclick="setActionResource('action')" id="save-action-btn" title="Set to the specified value">Set</button>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <th>Bonus Actions</th>
                            <td>
                                <div class="action-resource-controls">
                                    <input type="number" class="action-resource-input" id="bonus-action-input" value="{{ battle.entity_state_for(entity).get('bonus_action', 0) }}" min="0" max="10" title="Current number of bonus actions available">
                                    <div class="action-resource-buttons">
                                        <button class="action-resource-btn minus-btn" onclick="updateActionResource('bonus_action', -1)" title="Remove one bonus action">-</button>
                                        <button class="action-resource-btn plus-btn" onclick="updateActionResource('bonus_action', 1)" title="Add one bonus action">+</button>
                                        <button class="action-resource-save-btn" onclick="setActionResource('bonus_action')" id="save-bonus-action-btn" title="Set to the specified value">Set</button>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <th>Reactions</th>
                            <td>
                                <div class="action-resource-controls">
                                    <input type="number" class="action-resource-input" id="reaction-input" value="{{ battle.entity_state_for(entity).get('reaction', 0) }}" min="0" max="10" title="Current number of reactions available">
                                    <div class="action-resource-buttons">
                                        <button class="action-resource-btn minus-btn" onclick="updateActionResource('reaction', -1)" title="Remove one reaction">-</button>
                                        <button class="action-resource-btn plus-btn" onclick="updateActionResource('reaction', 1)" title="Add one reaction">+</button>
                                        <button class="action-resource-save-btn" onclick="setActionResource('reaction')" id="save-reaction-btn" title="Set to the specified value">Set</button>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    </table>
                    {% endif %}
                </div>
            </div>

            {% if not entity.object() and entity.ability_scores %}
