    <!-- Rest modal -->
    <div id="rest-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
        <div style="background:#fff; padding:18px 22px; border-radius:8px; min-width:340px; max-width:520px; max-height:80vh; overflow:auto;">
            <h3 id="rest-modal-title" style="margin-top:0;">Rest</h3>
            <div id="rest-modal-body" style="font-size:14px;">Loading…</div>
            <div id="rest-modal-error" style="color:#b00; margin-top:8px; display:none;"></div>
            <div style="margin-top:14px; display:flex; gap:8px; justify-content:flex-end;">
                <button type="button" class="hp-save-btn" onclick="closeRestModal()">Cancel</button>
                <button type="button" class="hp-save-btn" id="rest-modal-confirm" onclick="confirmRest()">Confirm</button>
            </div>
        </div>
    </div>

    <script>
        (function () {
            let restState = null;

            window.openRestModal = function (entityId, type) {
                restState = { entityId: entityId, type: type, picks: [], hitDicePicks: [], preview: null };
                document.getElementById('rest-modal-title').textContent =
                    (type === 'long' ? 'Long Rest' : 'Short Rest');
                document.getElementById('rest-modal-error').style.display = 'none';
                document.getElementById('rest-modal-body').textContent = 'Loading…';
                document.getElementById('rest-modal').style.display = 'flex';

                fetch('/rest/preview?entity_id=' + encodeURIComponent(entityId) + '&type=' + type)
                    .then(r => r.json())
                    .then(data => {
                        if (!data.success) {
                            renderRestError(data.error || 'Unable to load rest preview');
                            return;
                        }
                        restState.preview = data;
                        renderRestPreview(data);
                    })
                    .catch(err => renderRestError(String(err)));
            };

            window.closeRestModal = function () {
                document.getElementById('rest-modal').style.display = 'none';
                restState = null;
            };

            function renderRestError(msg) {
                const err = document.getElementById('rest-modal-error');
                err.textContent = msg;
                err.style.display = 'block';
            }

            function renderRestPreview(data) {
                const body = document.getElementById('rest-modal-body');
                const lines = [];
                lines.push('<div><strong>' + escapeHtml(data.entity_name) + '</strong> — ' +
                    (data.type === 'long' ? 'Long' : 'Short') + ' Rest</div>');
                lines.push('<div style="margin-top:6px;">HP: ' + data.state.hp + ' / ' + data.state.max_hp + '</div>');
                if (data.state.hit_die && Object.keys(data.state.hit_die).length) {
                    const hd = Object.entries(data.state.hit_die)
                        .map(([d, n]) => 'd' + d + ': ' + n).join(', ');
                    lines.push('<div>Hit Dice: ' + hd + '</div>');
                }
                if (data.type === 'short' && data.state.hit_die &&
                    Object.keys(data.state.hit_die).length) {
                    lines.push('<div style="margin-top:10px;"><strong>Spend Hit Dice</strong>' +
                        ' <span style="color:#666; font-size:12px;">(roll + CON mod to heal)</span></div>');
                    lines.push('<div id="hit-die-picks" style="margin-top:4px;"></div>');
                    lines.push('<div style="margin-top:6px; display:flex; gap:6px; flex-wrap:wrap;">');
                    Object.keys(data.state.hit_die)
                        .map(k => parseInt(k, 10))
                        .filter(k => !isNaN(k) && data.state.hit_die[k] > 0)
                        .sort((a, b) => a - b)
                        .forEach(die => {
                            lines.push('<button type="button" class="hp-save-btn" data-die="' + die +
                                '" onclick="addHitDiePick(' + die + ')">+d' + die + '</button>');
                        });
                    lines.push('<button type="button" class="hp-save-btn" onclick="clearHitDiePicks()">Clear</button>');
                    lines.push('</div>');
                    lines.push('<div style="color:#666; font-size:12px; margin-top:4px;">' +
                        'Leave empty to auto-spend dice until full HP.</div>');
                }
                if (data.in_combat && (!data.blocking_reasons || !data.blocking_reasons.length)) {
                    lines.push('<div style="margin-top:8px; color:#b00;">Combat is in progress.' +
                        (data.is_dm ? ' DM may force a rest below.' : '') + '</div>');
                    if (data.is_dm) {
                        lines.push('<label style="display:block; margin-top:6px;">' +
                            '<input type="checkbox" id="rest-force"> Force rest (DM override)</label>');
                    }
                }
                if (data.blocking_reasons && data.blocking_reasons.length) {
                    const items = data.blocking_reasons
                        .map(r => '<li>' + escapeHtml(r) + '</li>').join('');
                    lines.push('<div style="margin-top:8px; padding:6px 8px; ' +
                        'background:#fdecea; border-left:3px solid #b00; color:#7a1a14;">' +
                        '<strong>Cannot rest:</strong><ul style="margin:4px 0 0 18px; padding:0;">' +
                        items + '</ul>' +
                        (data.force_overrides && data.is_dm
                            ? '<div style="margin-top:4px; font-size:12px; color:#555;">' +
                              'A DM force-rest can bypass these restrictions.</div>'
                            : '') +
                        '</div>');
                    if (data.is_dm && data.force_overrides && !document.getElementById('rest-force')) {
                        lines.push('<label style="display:block; margin-top:6px;">' +
                            '<input type="checkbox" id="rest-force"> Force rest (DM override)</label>');
                    }
                }
                if (data.type === 'long' && data.requires_rations) {
                    const ok = (data.rations_available || 0) >= 1;
                    lines.push('<div style="margin-top:6px; color:' + (ok ? '#444' : '#b00') + ';">' +
                        'Rations available: ' + (data.rations_available || 0) +
                        ' (1 will be consumed)</div>');
                }
                if (data.arcane_recovery) {
                    const ar = data.arcane_recovery;
                    lines.push('<div style="margin-top:10px;"><strong>Arcane Recovery</strong> — budget ' +
                        ar.budget + '</div>');
                    if (ar.available_levels.length === 0) {
                        lines.push('<div>No spell slots are available to recover.</div>');
                    } else {
                        lines.push('<div style="margin-top:4px;">Choose slot levels to recover (totals must be ≤ ' +
                            ar.budget + '):</div>');
                        lines.push('<div id="arcane-picks" style="display:flex; flex-wrap:wrap; gap:6px; margin-top:4px;"></div>');
                        lines.push('<div style="margin-top:6px; display:flex; gap:6px;">');
                        ar.available_levels.forEach(lvl => {
                            lines.push('<button type="button" class="hp-save-btn" data-lvl="' + lvl +
                                '" onclick="addArcanePick(' + lvl + ')">+L' + lvl + '</button>');
                        });
                        lines.push('<button type="button" class="hp-save-btn" onclick="clearArcanePicks()">Clear</button>');
                        lines.push('</div>');
                    }
                }
                body.innerHTML = lines.join('');
                renderArcanePicks();
                renderHitDiePicks();
                // Disable confirm if blocked and force can't help (or user isn't DM).
                const confirmBtn = document.getElementById('rest-modal-confirm');
                if (confirmBtn) {
                    const blocked = data.blocking_reasons && data.blocking_reasons.length;
                    const canForce = data.is_dm && data.force_overrides;
                    confirmBtn.disabled = blocked && !canForce;
                    confirmBtn.title = (blocked && !canForce)
                        ? 'Cannot rest: ' + data.blocking_reasons.join('; ')
                        : '';
                }
            }

            function renderHitDiePicks() {
                const container = document.getElementById('hit-die-picks');
                if (!container || !restState) return;
                const available = (restState.preview && restState.preview.state &&
                    restState.preview.state.hit_die) || {};
                const used = {};
                restState.hitDicePicks.forEach(d => { used[d] = (used[d] || 0) + 1; });
                const items = restState.hitDicePicks.map((die, i) =>
                    '<span style="background:#efe; padding:2px 6px; border-radius:4px;">d' + die +
                    ' <a href="#" onclick="removeHitDiePick(' + i + '); return false;">×</a></span>'
                );
                const totals = Object.keys(available)
                    .map(k => parseInt(k, 10))
                    .filter(k => !isNaN(k))
                    .sort((a, b) => a - b)
                    .map(die => 'd' + die + ': ' + (used[die] || 0) + ' / ' + (available[die] || 0))
                    .join(', ');
                container.innerHTML = '<div>Selected: ' + (items.join(' ') || '<em>none</em>') +
                    '</div><div style="font-size:12px; color:#666;">' + totals + '</div>';
            }

            window.addHitDiePick = function (die) {
                if (!restState || !restState.preview) return;
                const available = (restState.preview.state && restState.preview.state.hit_die) || {};
                const used = restState.hitDicePicks.filter(d => d === die).length;
                if (used >= (available[die] || 0)) {
                    renderRestError('No more d' + die + ' hit dice available');
                    return;
                }
                document.getElementById('rest-modal-error').style.display = 'none';
                restState.hitDicePicks.push(die);
                renderHitDiePicks();
            };
            window.removeHitDiePick = function (idx) {
                if (!restState) return;
                restState.hitDicePicks.splice(idx, 1);
                renderHitDiePicks();
            };
            window.clearHitDiePicks = function () {
                if (!restState) return;
                restState.hitDicePicks = [];
                renderHitDiePicks();
            };

            function renderArcanePicks() {
                const container = document.getElementById('arcane-picks');
                if (!container || !restState) return;
                const ar = restState.preview && restState.preview.arcane_recovery;
                const budget = ar ? ar.budget : 0;
                const used = restState.picks.reduce((a, b) => a + b, 0);
                const items = restState.picks.map((lvl, i) =>
                    '<span style="background:#eef; padding:2px 6px; border-radius:4px;">L' + lvl +
                    ' <a href="#" onclick="removeArcanePick(' + i + '); return false;">×</a></span>'
                );
                container.innerHTML = '<div>Selected: ' + (items.join(' ') || '<em>none</em>') +
                    ' — used ' + used + ' / ' + budget + '</div>';
            }

            window.addArcanePick = function (lvl) {
                if (!restState || !restState.preview || !restState.preview.arcane_recovery) return;
                const ar = restState.preview.arcane_recovery;
                const used = restState.picks.reduce((a, b) => a + b, 0);
                if (used + lvl > ar.budget) {
                    renderRestError('Pick exceeds budget of ' + ar.budget);
                    return;
                }
                document.getElementById('rest-modal-error').style.display = 'none';
                restState.picks.push(lvl);
                renderArcanePicks();
            };
            window.removeArcanePick = function (idx) {
                if (!restState) return;
                restState.picks.splice(idx, 1);
                renderArcanePicks();
            };
            window.clearArcanePicks = function () {
                if (!restState) return;
                restState.picks = [];
                renderArcanePicks();
            };

            window.confirmRest = function () {
                if (!restState) return;
                const forceCheckbox = document.getElementById('rest-force');
                const payload = {
                    entity_id: restState.entityId,
                    type: restState.type,
                    force: forceCheckbox ? forceCheckbox.checked : false,
                    arcane_picks: restState.picks,
                    hit_die_picks: restState.hitDicePicks,
                };
                document.getElementById('rest-modal-error').style.display = 'none';
                document.getElementById('rest-modal-confirm').disabled = true;
                fetch('/rest', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                })
                    .then(r => r.json().then(d => ({ ok: r.ok, data: d })))
                    .then(({ ok, data }) => {
                        document.getElementById('rest-modal-confirm').disabled = false;
                        if (!ok || !data.success) {
                            renderRestError(data.error || 'Rest failed');
                            return;
                        }
                        closeRestModal();
                        if (typeof window.reloadEntityInfo === 'function') {
                            window.reloadEntityInfo();
                        } else {
                            window.location.reload();
                        }
                    })
                    .catch(err => {
                        document.getElementById('rest-modal-confirm').disabled = false;
                        renderRestError(String(err));
                    });
            };

            function escapeHtml(s) {
                return String(s == null ? '' : s)
                    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
            }

            // ---- Page-load rest availability indicators ----------------
            function applyRestAvailability(availability, isDm) {
                ['short', 'long'].forEach(function (kind) {
                    const btn = document.getElementById('rest-btn-' + kind);
                    if (!btn) return;
                    const info = availability && availability[kind];
                    if (!info) return;
                    const reasons = info.reasons || [];
                    if (info.allowed) {
                        btn.style.opacity = '';
                        btn.style.textDecoration = '';
                        btn.title = '';
                        return;
                    }
                    const canForce = isDm && info.force_overrides;
                    // Visual: dim when truly unavailable, italic-strike when DM-only.
                    btn.style.opacity = canForce ? '0.85' : '0.5';
                    btn.title = (canForce ? 'DM force required: ' : 'Cannot rest: ') +
                        reasons.join('; ');
                });
                const indicator = document.getElementById('rest-status-indicator');
                const detail = document.getElementById('rest-status-detail');
                if (!indicator || !detail) return;
                const blockedKinds = ['short', 'long']
                    .filter(k => availability && availability[k] && !availability[k].allowed);
                if (blockedKinds.length === 0) {
                    indicator.textContent = '';
                    detail.textContent = '';
                    return;
                }
                indicator.textContent = '⚠ Rest restricted';
                const reasonSet = new Set();
                blockedKinds.forEach(k => (availability[k].reasons || []).forEach(r => reasonSet.add(r)));
                detail.textContent = Array.from(reasonSet).join(' · ');
            }

            window.refreshRestAvailability = function () {
                const btn = document.getElementById('rest-btn-short') ||
                            document.getElementById('rest-btn-long');
                if (!btn) return;
                const entityId = btn.getAttribute('data-rest-entity');
                if (!entityId) return;
                fetch('/rest/preview?entity_id=' + encodeURIComponent(entityId) + '&type=short')
                    .then(r => r.json())
                    .then(data => {
                        if (!data || !data.success || !data.availability) return;
                        applyRestAvailability(data.availability, !!data.is_dm);
                    })
                    .catch(() => { /* silent: indicators are best-effort */ });
            };

            document.addEventListener('DOMContentLoaded', function () {
                if (document.getElementById('rest-btn-short') ||
                    document.getElementById('rest-btn-long')) {
                    window.refreshRestAvailability();
                }
            });
        })();
    </script>

    {% if entity.__class__.__name__ == 'PlayerCharacter' and not entity.object() %}
    <script>
        (function () {
            const root = document.querySelector('.journal-section[data-entity-uid]');
            if (!root) return;
            const entityUid = root.getAttribute('data-entity-uid');
            const entriesEl = root.querySelector('.journal-entries');
            const searchEl = root.querySelector('.journal-search');
            const kindEl = root.querySelector('.journal-kind-filter');
            const formEl = root.querySelector('.journal-add-form');
            const textEl = root.querySelector('.journal-add-text');
            const addBtn = root.querySelector('.journal-add-btn');
            let debounceId = null;

            function esc(s) {
                return String(s == null ? '' : s)
                    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
            }

            function fmtTs(ts) {
                if (!ts) return '';
                try {
                    const d = new Date(ts);
                    if (isNaN(d.getTime())) return ts;
                    return d.toLocaleString();
                } catch (e) { return ts; }
            }

            function render(entries) {
                if (!entries || !entries.length) {
                    entriesEl.innerHTML = '<em class="journal-empty">No entries yet.</em>';
                    return;
                }
                const html = entries.slice().reverse().map(function (e) {
                    const kind = e.kind || 'note';
                    const tags = (e.tags || []).map(function (t) {
                        return '<span class="journal-tag">' + esc(t) + '</span>';
                    }).join('');
                    const title = e.title ? '<div class="journal-entry-title">' + esc(e.title) + '</div>' : '';
                    const meta = '<div class="journal-entry-meta">' + esc(kind) + ' &middot; ' + esc(fmtTs(e.ts)) +
                        (e.source ? ' &middot; ' + esc(e.source) : '') + '</div>';
                    return '<div class="journal-entry kind-' + esc(kind) + '" data-id="' + esc(e.id) + '">' +
                        '<button class="journal-entry-delete" title="Delete">&times;</button>' +
                        meta + title +
                        '<div class="journal-entry-text">' + esc(e.text) + '</div>' +
                        (tags ? '<div>' + tags + '</div>' : '') +
                        '</div>';
                }).join('');
                entriesEl.innerHTML = html;
            }

            function load() {
                const params = new URLSearchParams();
                if (searchEl.value.trim()) params.set('q', searchEl.value.trim());
                if (kindEl.value) params.set('kind', kindEl.value);
                fetch('/character/' + encodeURIComponent(entityUid) + '/journal?' + params.toString(), {
                    credentials: 'same-origin'
                })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (data && data.entries) render(data.entries);
                        else entriesEl.innerHTML = '<em class="journal-empty">' + esc(data && data.error || 'Unable to load journal.') + '</em>';
                    })
                    .catch(function () {
                        entriesEl.innerHTML = '<em class="journal-empty">Failed to load journal.</em>';
                    });
            }

            function debouncedLoad() {
                if (debounceId) clearTimeout(debounceId);
                debounceId = setTimeout(load, 180);
            }

            searchEl.addEventListener('input', debouncedLoad);
            kindEl.addEventListener('change', load);

            formEl.addEventListener('submit', function (ev) {
                ev.preventDefault();
                const text = (textEl.value || '').trim();
                if (!text) return;
                addBtn.disabled = true;
                fetch('/character/' + encodeURIComponent(entityUid) + '/journal', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: text })
                })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        addBtn.disabled = false;
                        if (data && data.entry) {
                            textEl.value = '';
                            load();
                        } else {
                            alert((data && data.error) || 'Failed to add entry.');
                        }
                    })
                    .catch(function () {
                        addBtn.disabled = false;
                        alert('Failed to add entry.');
                    });
            });

            entriesEl.addEventListener('click', function (ev) {
                const btn = ev.target.closest('.journal-entry-delete');
                if (!btn) return;
                const entry = btn.closest('.journal-entry');
                if (!entry) return;
                const id = entry.getAttribute('data-id');
                if (!id) return;
                if (!confirm('Delete this journal entry?')) return;
                fetch('/character/' + encodeURIComponent(entityUid) + '/journal/' + encodeURIComponent(id), {
                    method: 'DELETE',
                    credentials: 'same-origin'
                })
                    .then(function (r) { return r.json(); })
                    .then(function () { load(); })
                    .catch(function () { alert('Failed to delete entry.'); });
            });

            // Live refresh from socket events.
            try {
                if (window.io) {
                    const sock = window.__journalSocket || io();
                    window.__journalSocket = sock;
                    sock.on('message', function (msg) {
                        if (msg && msg.type === 'journal_update' &&
                            Array.isArray(msg.entity_uids) &&
                            msg.entity_uids.indexOf(entityUid) !== -1) {
                            load();
                        }
                    });
                }
            } catch (e) { /* socket optional */ }

            load();
        })();
    </script>
    {% endif %}

    {% if 'dm' in role %}
    <script>
        (function () {
            const section = document.querySelector('.dm-inventory-section');
            if (!section) return;
            const entityUid = section.getAttribute('data-entity-uid');
            const datalist = section.querySelector('datalist');
            const searchInput = section.querySelector('.dm-inventory-item-search');
            const qtyInput = section.querySelector('.dm-inventory-qty');
            const addBtn = section.querySelector('.dm-inventory-add-btn');
            const status = section.querySelector('.dm-inventory-add-status');
            const tbody = section.querySelector('.dm-inventory-tbody');

            let catalog = [];
            const labelToName = new Map();

            function setStatus(msg, isError) {
                status.textContent = msg || '';
                status.style.color = isError ? '#e57373' : '#9ccc65';
            }

            function renderCatalog() {
                datalist.innerHTML = '';
                labelToName.clear();
                const frag = document.createDocumentFragment();
                catalog.forEach(function (item) {
                    const opt = document.createElement('option');
                    const display = item.label + '  [' + item.category + ']';
                    opt.value = display;
                    opt.setAttribute('data-name', item.name);
                    frag.appendChild(opt);
                    labelToName.set(display.toLowerCase(), item.name);
                    labelToName.set(item.label.toLowerCase(), item.name);
                    labelToName.set(item.name.toLowerCase(), item.name);
                });
                datalist.appendChild(frag);
            }

            function loadCatalog() {
                fetch('/dm/items_catalog', { credentials: 'same-origin' })
                    .then(function (r) { return r.ok ? r.json() : Promise.reject(r); })
                    .then(function (data) {
                        catalog = (data && data.items) || [];
                        renderCatalog();
                    })
                    .catch(function () { setStatus('Failed to load catalog', true); });
            }

            function renderInventory(items) {
                tbody.innerHTML = '';
                if (!items || !items.length) {
                    const tr = document.createElement('tr');
                    tr.innerHTML = '<td colspan="4" style="color:#888;">Inventory is empty.</td>';
                    tbody.appendChild(tr);
                    return;
                }
                items.forEach(function (it) {
                    const tr = document.createElement('tr');
                    tr.innerHTML =
                        '<td>' + escapeHtml(it.label) + ' <span style="color:#888;font-size:0.8em">(' + escapeHtml(it.name) + ')</span></td>' +
                        '<td>' + escapeHtml(it.type || '') + '</td>' +
                        '<td style="text-align:right;">' + it.qty + '</td>' +
                        '<td style="text-align:right; white-space:nowrap;">' +
                            '<button type="button" class="dm-inv-remove-one" data-name="' + escapeAttr(it.name) + '">-1</button> ' +
                            '<button type="button" class="dm-inv-remove-all" data-name="' + escapeAttr(it.name) + '">Remove All</button>' +
                        '</td>';
                    tbody.appendChild(tr);
                });
            }

            function escapeHtml(s) {
                return String(s == null ? '' : s).replace(/[&<>"]/g, function (c) {
                    return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
                });
            }
            function escapeAttr(s) { return escapeHtml(s).replace(/'/g, '&#39;'); }

            function loadInventory() {
                fetch('/dm/inventory?id=' + encodeURIComponent(entityUid), { credentials: 'same-origin' })
                    .then(function (r) { return r.ok ? r.json() : Promise.reject(r); })
                    .then(function (data) { renderInventory((data && data.items) || []); })
                    .catch(function () {
                        tbody.innerHTML = '<tr><td colspan="4" style="color:#e57373;">Failed to load inventory.</td></tr>';
                    });
            }

            function resolveItemName(typed) {
                if (!typed) return null;
                const key = typed.trim().toLowerCase();
                if (labelToName.has(key)) return labelToName.get(key);
                // fall back to fuzzy contains match
                const match = catalog.find(function (it) {
                    return it.name.toLowerCase() === key || it.label.toLowerCase() === key;
                });
                if (match) return match.name;
                const partial = catalog.find(function (it) {
                    return it.label.toLowerCase().indexOf(key) === 0 || it.name.toLowerCase().indexOf(key) === 0;
                });
                return partial ? partial.name : null;
            }

            addBtn.addEventListener('click', function () {
                const typed = searchInput.value;
                const itemName = resolveItemName(typed);
                if (!itemName) {
                    setStatus('No matching item: ' + typed, true);
                    return;
                }
                const qty = Math.max(1, parseInt(qtyInput.value, 10) || 1);
                addBtn.disabled = true;
                fetch('/dm/inventory/add', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ entity_id: entityUid, item_name: itemName, qty: qty })
                })
                    .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, body: j }; }); })
                    .then(function (res) {
                        if (!res.ok || !res.body || !res.body.success) {
                            setStatus((res.body && res.body.error) || 'Failed to add item', true);
                            return;
                        }
                        setStatus('Added ' + qty + ' x ' + itemName + ' (now ' + res.body.qty + ')', false);
                        searchInput.value = '';
                        qtyInput.value = '1';
                        loadInventory();
                    })
                    .catch(function () { setStatus('Network error adding item', true); })
                    .finally(function () { addBtn.disabled = false; });
            });

            searchInput.addEventListener('keydown', function (ev) {
                if (ev.key === 'Enter') { ev.preventDefault(); addBtn.click(); }
            });

            tbody.addEventListener('click', function (ev) {
                const target = ev.target;
                if (!(target instanceof HTMLElement)) return;
                const name = target.getAttribute('data-name');
                if (!name) return;
                const isAll = target.classList.contains('dm-inv-remove-all');
                const isOne = target.classList.contains('dm-inv-remove-one');
                if (!isAll && !isOne) return;
                target.disabled = true;
                fetch('/dm/inventory/remove', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ entity_id: entityUid, item_name: name, qty: 1, all: !!isAll })
                })
                    .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, body: j }; }); })
                    .then(function (res) {
                        if (!res.ok || !res.body || !res.body.success) {
                            setStatus((res.body && res.body.error) || 'Failed to remove', true);
                            return;
                        }
                        setStatus('Removed ' + name + ' (now ' + res.body.qty + ')', false);
                        loadInventory();
                    })
                    .catch(function () { setStatus('Network error removing item', true); })
                    .finally(function () { target.disabled = false; });
            });

            loadCatalog();
            loadInventory();
        })();
    </script>
    {% endif %}
</body>
</html>
