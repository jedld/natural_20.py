        <style>
            .journal-section { display: flex; flex-direction: column; gap: 10px; }
            .journal-controls { display: flex; gap: 8px; }
            .journal-search { flex: 1; padding: 6px 8px; border: 1px solid #555; background: #2a2a2a; color: #eee; border-radius: 4px; }
            .journal-kind-filter { padding: 6px 8px; border: 1px solid #555; background: #2a2a2a; color: #eee; border-radius: 4px; }
            .journal-entries { max-height: 420px; overflow-y: auto; border: 1px solid #444; border-radius: 4px; padding: 6px; background: #1c1c1c; }
            .journal-empty { color: #888; font-style: italic; padding: 8px; display: block; }
            .journal-entry { padding: 8px 10px; margin-bottom: 6px; background: #262626; border-left: 4px solid #777; border-radius: 3px; position: relative; }
            .journal-entry .journal-entry-meta { font-size: 0.8em; color: #aaa; margin-bottom: 4px; }
            .journal-entry .journal-entry-text { color: #eee; white-space: pre-wrap; }
            .journal-entry .journal-entry-title { font-weight: 700; color: #f1c40f; margin-bottom: 2px; }
            .journal-entry .journal-entry-delete { position: absolute; top: 6px; right: 8px; background: none; border: none; color: #c0392b; cursor: pointer; font-size: 0.9em; }
            .journal-entry .journal-entry-delete:hover { color: #e74c3c; }
            .journal-entry.kind-narration { border-left-color: #c97f4a; }
            .journal-entry.kind-note { border-left-color: #6cb04a; }
            .journal-entry.kind-dm { border-left-color: #a073d6; }
            .journal-entry.kind-chat { border-left-color: #4ab0c9; }
            .journal-tag { display: inline-block; background: #3a3a3a; color: #ddd; padding: 1px 6px; margin-right: 4px; border-radius: 8px; font-size: 0.75em; }
            .journal-add-form { display: flex; flex-direction: column; gap: 6px; }
            .journal-add-text { padding: 6px 8px; border: 1px solid #555; background: #2a2a2a; color: #eee; border-radius: 4px; resize: vertical; font-family: inherit; }
            .journal-add-btn { align-self: flex-end; padding: 6px 14px; background: #8a6d3b; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-weight: 600; }
            .journal-add-btn:hover { background: #a0824a; }
            .journal-add-btn:disabled { background: #555; cursor: not-allowed; }
        </style>
        {% endif %}
        {% endif %}
    </div>
    <script src="{{ asset_url('sheet.js') }}"></script>
    <script src="{{ asset_url('utils.js') }}"></script>
    <script>
        // HP Update Functions for DM
        function updateMaxHP() {
            const input = document.getElementById('max-hp-input');
            const button = document.getElementById('save-max-hp-btn');
            const value = parseInt(input.value);
            
            if (isNaN(value) || value < 1) {
                alert('Max HP must be a positive number');
                return;
            }
            
            button.disabled = true;
            button.textContent = 'Saving...';
            
            fetch('/update_hp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    entity_id: document.body.dataset.id,
                    hp_type: 'max_hp',
                    value: value
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    button.textContent = 'Saved!';
                    setTimeout(() => {
                        button.textContent = 'Save';
                        button.disabled = false;
                    }, 1000);
                    // Update current HP max constraint
                    const currentHPInput = document.getElementById('current-hp-input');
                    if (currentHPInput) {
                        currentHPInput.max = value;
                    }
                } else {
                    alert('Failed to update Max HP: ' + (data.error || 'Unknown error'));
                    button.textContent = 'Save';
                    button.disabled = false;
                }
            })
            .catch(error => {
                alert('Error updating Max HP: ' + error);
                button.textContent = 'Save';
                button.disabled = false;
            });
        }
        
        function updateCurrentHP() {
            const input = document.getElementById('current-hp-input');
            const button = document.getElementById('save-current-hp-btn');
            const value = parseInt(input.value);
            const maxHP = parseInt(document.getElementById('max-hp-input')?.value || input.max);
            
            if (isNaN(value) || value < 0) {
                alert('Current HP must be 0 or greater');
                return;
            }
            
            if (value > maxHP) {
                alert('Current HP cannot exceed Max HP (' + maxHP + ')');
                return;
            }
            
            button.disabled = true;
            button.textContent = 'Saving...';
            
            fetch('/update_hp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    entity_id: document.body.dataset.id,
                    hp_type: 'current_hp',
                    value: value
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    button.textContent = 'Saved!';
                    setTimeout(() => {
                        button.textContent = 'Save';
                        button.disabled = false;
                    }, 1000);
                } else {
                    alert('Failed to update Current HP: ' + (data.error || 'Unknown error'));
                    button.textContent = 'Save';
                    button.disabled = false;
                }
            })
            .catch(error => {
                alert('Error updating Current HP: ' + error);
                button.textContent = 'Save';
                button.disabled = false;
            });
        }
        
        function updateTempHP() {
            const input = document.getElementById('temp-hp-input');
            const button = document.getElementById('save-temp-hp-btn');
            const value = parseInt(input.value);
            
            if (isNaN(value) || value < 0) {
                alert('Temporary HP must be 0 or greater');
                return;
            }
            
            button.disabled = true;
            button.textContent = 'Saving...';
            
            fetch('/update_hp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    entity_id: document.body.dataset.id,
                    hp_type: 'temp_hp',
                    value: value
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    button.textContent = 'Saved!';
                    setTimeout(() => {
                        button.textContent = 'Save';
                        button.disabled = false;
                    }, 1000);
                } else {
                    alert('Failed to update Temporary HP: ' + (data.error || 'Unknown error'));
                    button.textContent = 'Save';
                    button.disabled = false;
                }
            })
            .catch(error => {
                alert('Error updating Temporary HP: ' + error);
                button.textContent = 'Save';
                button.disabled = false;
            });
        }

        // Action Resource Update Functions for DM
        function updateActionResource(resourceType, change) {
            const input = document.getElementById(resourceType.replace('_', '-') + '-input');
            const currentValue = parseInt(input.value) || 0;
            const newValue = Math.max(0, Math.min(10, currentValue + change));
            input.value = newValue;
            
            // Auto-save the change
            setActionResource(resourceType);
        }
        
        function setActionResource(resourceType) {
            const input = document.getElementById(resourceType.replace('_', '-') + '-input');
            const button = document.getElementById('save-' + resourceType.replace('_', '-') + '-btn');
            const value = parseInt(input.value);
            
            if (isNaN(value) || value < 0) {
                alert('Resource value must be 0 or greater');
                return;
            }
            
            button.disabled = true;
            button.textContent = 'Saving...';
            
            fetch('/update_action_resources', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    entity_id: document.body.dataset.id,
                    resource_type: resourceType,
                    value: value,
                    operation: 'set'
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    button.textContent = 'Saved!';
                    setTimeout(() => {
                        button.textContent = 'Set';
                        button.disabled = false;
                    }, 1000);
                } else {
                    alert('Failed to update ' + resourceType.replace('_', ' ') + ': ' + (data.error || 'Unknown error'));
                    button.textContent = 'Set';
                    button.disabled = false;
                }
            })
            .catch(error => {
                alert('Error updating ' + resourceType.replace('_', ' ') + ': ' + error);
                button.textContent = 'Set';
                button.disabled = false;
            });
        }

        // Spell Slot Update Functions for DM
        function updateSpellSlots(entityId, characterClass, level, value) {
            const input = document.querySelector(`input[data-entity-id="${entityId}"][data-class="${characterClass}"][data-level="${level}"]`);
            if (!input) return;
            
            const numValue = parseInt(value);
            const maxValue = parseInt(input.max);
            
            if (isNaN(numValue) || numValue < 0) {
                alert('Spell slot value must be 0 or greater');
                input.value = input.defaultValue; // Reset to previous value
                return;
            }
            
            if (numValue > maxValue) {
                alert(`Spell slots cannot exceed maximum (${maxValue})`);
                input.value = maxValue;
                return;
            }
            
            fetch('/update_spell_slots', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    entity_id: entityId,
                    character_class: characterClass,
                    level: parseInt(level),
                    value: numValue,
                    operation: 'set'
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Update the input value to reflect the actual saved value
                    input.value = data.new_value;
                    input.defaultValue = data.new_value;
                    
                    // Show brief success feedback
                    const originalBg = input.style.backgroundColor;
                    input.style.backgroundColor = '#d4edda';
                    setTimeout(() => {
                        input.style.backgroundColor = originalBg;
                    }, 1000);
                } else {
                    alert('Failed to update spell slots: ' + (data.error || 'Unknown error'));
                    input.value = input.defaultValue; // Reset to previous value
                }
            })
            .catch(error => {
                alert('Error updating spell slots: ' + error);
                input.value = input.defaultValue; // Reset to previous value
            });
        }
        
        function adjustSpellSlots(entityId, characterClass, level, operation, amount) {
            const input = document.querySelector(`input[data-entity-id="${entityId}"][data-class="${characterClass}"][data-level="${level}"]`);
            if (!input) return;
            
            const currentValue = parseInt(input.value) || 0;
            const maxValue = parseInt(input.max);
            let newValue;
            
            if (operation === 'add') {
                newValue = Math.min(currentValue + amount, maxValue);
            } else if (operation === 'subtract') {
                newValue = Math.max(currentValue - amount, 0);
            } else {
                return;
            }
            
            if (newValue === currentValue) {
                return; // No change needed
            }
            
            fetch('/update_spell_slots', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    entity_id: entityId,
                    character_class: characterClass,
                    level: parseInt(level),
                    value: newValue,
                    operation: 'set'
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Update the input value to reflect the actual saved value
                    input.value = data.new_value;
                    input.defaultValue = data.new_value;
                    
                    // Show brief success feedback
                    const originalBg = input.style.backgroundColor;
                    input.style.backgroundColor = '#d4edda';
                    setTimeout(() => {
                        input.style.backgroundColor = originalBg;
                    }, 1000);
                } else {
                    alert('Failed to update spell slots: ' + (data.error || 'Unknown error'));
                }
            })
            .catch(error => {
                alert('Error updating spell slots: ' + error);
            });
        }

        // Add Enter key support for HP inputs
        document.addEventListener('DOMContentLoaded', function() {
            const maxHPInput = document.getElementById('max-hp-input');
            const currentHPInput = document.getElementById('current-hp-input');
            const tempHPInput = document.getElementById('temp-hp-input');
            
            // Action resource inputs
            const actionInput = document.getElementById('action-input');
            const bonusActionInput = document.getElementById('bonus-action-input');
            const reactionInput = document.getElementById('reaction-input');
            
            if (maxHPInput) {
                maxHPInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        updateMaxHP();
                    }
                });
            }
            
            if (currentHPInput) {
                currentHPInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        updateCurrentHP();
                    }
                });
            }
            
            if (tempHPInput) {
                tempHPInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        updateTempHP();
                    }
                });
            }
            
            if (actionInput) {
                actionInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        setActionResource('action');
                    }
                });
            }
            
            if (bonusActionInput) {
                bonusActionInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        setActionResource('bonus_action');
                    }
                });
            }
            
            if (reactionInput) {
                reactionInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        setActionResource('reaction');
                    }
                });
            }
            
            // Add Enter key support for spell slot inputs
            const spellSlotInputs = document.querySelectorAll('.spell-slot-input');
            spellSlotInputs.forEach(input => {
                input.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        const entityId = this.dataset.entityId;
                        const characterClass = this.dataset.class;
                        const level = this.dataset.level;
                        updateSpellSlots(entityId, characterClass, level, this.value);
                    }
                });
                
                // Store the default value for reset purposes
                input.defaultValue = input.value;
            });
        });
    </script>
